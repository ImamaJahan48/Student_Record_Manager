import csv
# Function: Load students from CSV
def load_students(filename='students.csv'):
    students = []
    try:
        with open(filename, 'r') as file:
            reader = csv.DictReader(file)
            for row in reader:
                students.append({
                    'roll_no': row['roll_no'],
                    'name': row['name'],
                    'marks': int(row['marks'])
                })
    except FileNotFoundError:
        # File doesn't exist yet, start empty
        pass
    return students
# Function: Save students to CSV
def save_students(students, filename='students.csv'):
    with open(filename, 'w', newline='') as file:
        fieldnames = ['roll_no', 'name', 'marks']
        writer = csv.DictWriter(file, fieldnames=fieldnames)
        writer.writeheader()
        for student in students:
            writer.writerow(student)
# Function: Add student
def add_student(students):
    roll_no = input("Enter Roll Number: ")
    name = input("Enter Name: ")
    marks = int(input("Enter Marks: "))
    students.append({'roll_no': roll_no, 'name': name, 'marks': marks})

    # --- CHANGE: Auto-save after adding ---
    save_students(students)
    print(f"Student {name} added successfully!")
# Function: View all students
def view_students(students):
    if not students:
        print("No students found.")
        return
    print("Roll No | Name | Marks")
    print("----------------------")
    for s in students:
        print(f"{s['roll_no']} | {s['name']} | {s['marks']}")
# Function: Search student
def search_student(students):
    roll_no = input("Enter Roll Number to search: ")
    for s in students:
        if s['roll_no'] == roll_no:
            print(f"Found: {s['roll_no']} | {s['name']} | {s['marks']}")
            return
    print("Student not found.")
# Function: Update student marks
def update_student(students):
    roll_no = input("Enter Roll Number to update: ")
    for s in students:
        if s['roll_no'] == roll_no:
            new_marks = int(input(f"Enter new marks for {s['name']}: "))
            s['marks'] = new_marks

            # --- CHANGE: Auto-save after update ---
            save_students(students)
            print("Marks updated successfully!")
            return
    print("Student not found.")
# Function: Delete student
def delete_student(students):
    roll_no = input("Enter Roll Number to delete: ")
    for s in students:
        if s['roll_no'] == roll_no:
            students.remove(s)

            # --- CHANGE: Auto-save after deletion ---
            save_students(students)
            print(f"Student {s['name']} deleted successfully!")
            return
    print("Student not found.")
# Main Menu
def main():
    students = load_students()  # Load data from CSV on start
    while True:
        print("\n--- Student Record Manager ---")
        print("1. Add Student")
        print("2. View All Students")
        print("3. Search Student")
        print("4. Update Student Marks")
        print("5. Delete Student")
        print("6. Exit")

        choice = input("Enter your choice (1-6): ")

        if choice == '1':
            add_student(students)
        elif choice == '2':
            view_students(students)
        elif choice == '3':
            search_student(students)
        elif choice == '4':
            update_student(students)
        elif choice == '5':
            delete_student(students)
        elif choice == '6':
            # --- CHANGE: Save before exiting (extra safety) ---
            save_students(students)
            print("Data saved. Exiting...")
            break
        else:
            print("Invalid choice! Try again.")

if __name__ == "__main__":
    main()

